# Forkwatch regtest knobs — the single place to tweak the simulated chain.
#
#   edit this file, then:  sg docker -c 'bash scripts/regtest.sh reset'
#   one-off:               sg docker -c 'bash scripts/regtest.sh reset LEAD_BLOCKS=20'
#
# The regtest chain is a SCALED MIRROR of the mainnet deployment: same structure, smaller numbers.
# Mainnet's floor (927360) and fork (961632) both sit exactly on 2016-block retarget boundaries,
# 17 epochs apart, with 600s blocks. Here the reset reproduces that shape — floor and fork on
# retarget boundaries, VISIBLE_EPOCHS apart, at BLOCK_SPACING_SECS per block — so every height-,
# epoch- and ETA-dependent code path in the app runs the same way it will on mainnet, only faster.
#
# Heights are NOT mainnet's: mining a real 961,632-block chain costs ~3 hours per rebuild, which
# is the wrong trade when the point is iterating on fork behavior. Everything else mirrors.
#
# FORK_AT_HEIGHT and FLOOR_HEIGHT are derived at reset time (RDTS activation lands on an
# unpredictable height, and both are rounded up to retarget boundaries from there) and written to
# compose/.regtest.runtime.env. Everything below is yours to change.

# Seconds per block — mainnet's 600, scaled down. Used for BOTH the historical timestamps written
# during the reset AND the live miner's cadence, so measured spacing matches intent and the header
# ETA is honest. This is the master pacing knob: at 20s the LEAD_BLOCKS countdown below is ~33min.
BLOCK_SPACING_SECS=20

# Blocks between the post-reset tip and the fork — the "watch it coming" window the miner walks
# live. LEAD_BLOCKS * BLOCK_SPACING_SECS seconds until the chains split.
LEAD_BLOCKS=100

# Size of the app's visible window, in 2016-block retarget epochs: FLOOR_HEIGHT = FORK_AT_HEIGHT -
# VISIBLE_EPOCHS*2016. Mainnet runs 17 (927360 -> 961632). 2 is the practical minimum that keeps a
# full retarget period of history below the fork, which is what the signaling gauge measures over.
# Raising this lengthens the reset (more blocks to mine and to backfill into the app's SQLite).
VISIBLE_EPOCHS=2

# Blocks per difficulty epoch. Mainnet's 2016; also the BIP9 signaling period the gauge reports.
RETARGET_INTERVAL=2016

# PRE-FORK, on the shared chain: Knots' hashrate in blocks per 100. 1 ~= reality. Applies to both
# the prefilled history and the live miner, so the chain's bit-4 share matches the hashrate story
# throughout. Only blocks above FLOOR_HEIGHT are interleaved this way — history below the floor is
# never ingested by the app, so it is bulk-mined on Core for speed.
KNOTS_PER_100=1

# POST-FORK, on its own branch: how often Knots mines. Once the chains split there is no shared tip
# to contend for, so the minority chain runs on its own clock instead of a share of Core's. At 60s
# against Core's BLOCK_SPACING_SECS the split widens ~3:1 — Knots visibly alive, visibly losing.
# Extrapolating KNOTS_PER_100 here instead would mean one Knots block every ~30 minutes: true to a
# 1% hashrate, useless to watch.
KNOTS_INTERVAL_SECS=60

# Bytes of OP_RETURN payload in the fork-triggering tx. Anything over 83 violates RDTS rule 1.
VIOLATION_BYTES=200

# Fallback fork distance used only if the miner starts on a chain already past FORK_AT_HEIGHT
# (e.g. you restarted the miner after the fork). Normal resets never hit this.
PRE_FORK_BLOCKS=18

# What the UI header calls the countdown target.
FORK_LABEL=Scheduled fork

# App ingest poll interval (ms).
POLL_MS=2000
