# Forkwatch — PRODUCTION (public internet, Cloudflare Tunnel) configuration.
#
# Copy this file to `compose/.env` and fill in the real values (at minimum FW_RPC_PASS and
# FW_CF_TUNNEL_TOKEN):
#
#     cp compose/.env.prod.example compose/.env
#     edit compose/.env
#
# `compose/.env` is gitignored and holds the deployment's real secrets. Docker Compose auto-loads it
# because it sits next to the compose file. The prod stack reads it with no extra flags:
#
#     docker compose -f compose/docker-compose.prod.yml up -d
#
# The compose file supplies safe defaults for everything EXCEPT the two required secrets below, so a
# missing secret fails loudly instead of silently using a baked-in one.

# --- Cloudflare Tunnel (public ingress) ----------------------------------------------------------
# REQUIRED. Create a tunnel in the Cloudflare Zero Trust dashboard (Networks -> Tunnels), add a
# public hostname (e.g. forkwatch.example.com) pointing at http://app:8080, and paste its token
# here. This is the ONLY thing that exposes the app to the internet — no inbound ports are opened.
FW_CF_TUNNEL_TOKEN=paste_your_cloudflare_tunnel_token_here

# --- Node RPC (backend <-> bitcoind, over the internal fwnet network) ----------------------------
# The user/password must match on both sides. The node entrypoint turns them into an rpcauth SALTED
# HASH written to a 0600 file inside the container, so the password never appears on a command line
# (host `ps aux` is readable by any local account); the backend still authenticates with the
# plaintext over the internal network. This file is the single source of truth.
FW_CORE_RPC_URL=http://core:8332
FW_KNOTS_RPC_URL=http://knots:8332
FW_RPC_USER=forkwars
# REQUIRED — no default. Use a long, shell-safe (no spaces/quotes) password:  openssl rand -base64 32
# Do NOT reuse forkwars_mainnet / forkwars_regtest: both are committed in this repo's git history
# and are permanently burned. deploy-prod.sh refuses to start if it sees either.
FW_RPC_PASS=change_me_before_deploying

# --- App / ingest --------------------------------------------------------------------------------
FW_NETWORK=mainnet
FW_POLL_MS=5000
# SQLite cache of block history. Keep as forkwars.db: renaming orphans the cached history the pruned
# nodes can no longer re-supply.
FW_DB_PATH=/data/forkwars.db
# Readiness fails if the last successful ingest poll is older than this (seconds).
FW_READY_MAX_STALE_SECS=60
# Log filter (RUST_LOG syntax).
FW_RUST_LOG=forkwars_backend=info,tower_http=warn,axum::rejection=warn
# Ceiling on concurrent WebSocket connections; over-cap upgrades get a 503 and the client falls back
# to polling (absorbed by the edge cache). Bounds memory under a connection flood.
FW_WS_MAX_CONNS=5000

# --- Resource limits -----------------------------------------------------------------------------
# Defaults in the compose file assume a ~16 GB box. RE-CHECK BEFORE FIRST DEPLOY: a limit set below
# what bitcoind actually needs turns a slow sync into an OOM-kill loop, so err high — these are a
# blast-radius guard, not tight packing. If you change FW_NODE_MEM_LIMIT, change `dbcache` in
# nodes/core/mainnet.conf and nodes/knots/mainnet.conf to match (450 MiB pairs with ~5g).
#   8 GB box  -> FW_NODE_MEM_LIMIT=2500m + dbcache=300
#   32 GB box -> FW_NODE_MEM_LIMIT=8g    + dbcache=1000 (faster IBD)
FW_NODE_MEM_LIMIT=5g
FW_APP_MEM_LIMIT=768m
FW_TOR_MEM_LIMIT=256m
FW_CLOUDFLARED_MEM_LIMIT=256m
# Minimum free space (GB) the deploy script requires before starting. Two pruned nodes are ~146 GiB
# each, plus chainstate, the ~11 GB snapshot, the app DB and rotated logs.
FW_MIN_DISK_GB=500

# --- BIP-110 / RDTS milestones (all on 2016-block retarget boundaries) ---------------------------
FW_FLOOR_HEIGHT=927360
FW_FORK_AT_HEIGHT=961632
FW_FORK_LABEL="Mandatory signaling"
FW_TARGET_SPACING_SECS=600
FW_RETARGET_INTERVAL=2016

# --- Node bootstrap (assumeutxo snapshot) --------------------------------------------------------
# The snapshot file must exist at compose/../snapshots/utxo-840000.dat on the host (~11 GB, not in
# git). Generate it with `dumptxoutset` from a trusted node, or copy it in, before first start.
FW_LOAD_SNAPSHOT=/snapshots/utxo-840000.dat
FW_SNAPSHOT_HEIGHT=840000

# NOTE: the LAN-only knobs (FW_APP_PORT, FW_MDNS_NAME) are intentionally absent — the prod stack
# publishes no host port and runs no mDNS advertiser.
