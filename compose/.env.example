# Forkwatch — MAINNET (production) configuration.
#
# Copy this file to `compose/.env` and fill in the real values (at minimum FW_RPC_PASS):
#
#     cp compose/.env.example compose/.env
#     edit compose/.env
#
# `compose/.env` is gitignored — it holds the deployment's real secrets and never gets committed.
# Docker Compose auto-loads it because it sits next to docker-compose.mainnet.yml (the project
# directory is the compose file's directory, NOT the repo root). The mainnet stack reads it with no
# extra flags:
#
#     docker compose -f compose/docker-compose.mainnet.yml up -d
#
# Every value below feeds compose variable-substitution in docker-compose.mainnet.yml. The compose
# file supplies safe defaults for all of these EXCEPT FW_RPC_PASS, which is required — the stack
# refuses to start until it is set, so a missing secret fails loudly instead of silently using a
# baked-in one. (The regtest/e2e stack is configured separately via compose/regtest.env.)

# --- Node RPC (backend <-> bitcoind, over the internal fwnet network) ----------------------------
# The user/password must match on both sides; they are injected into the bitcoind nodes (via the
# node entrypoint) AND handed to the backend + miner, so this file is the single source of truth.
FW_CORE_RPC_URL=http://core:8332
FW_KNOTS_RPC_URL=http://knots:8332
FW_RPC_USER=forkwars
# REQUIRED — no default. Use a long, shell-safe (no spaces/quotes) password in production.
FW_RPC_PASS=change_me_before_deploying

# --- App / ingest --------------------------------------------------------------------------------
FW_NETWORK=mainnet
FW_POLL_MS=5000
# SQLite cache of block history. Keep as forkwars.db: renaming orphans the cached history the pruned
# nodes can no longer re-supply.
FW_DB_PATH=/data/forkwars.db
# Readiness fails if the last successful ingest poll is older than this (seconds).
FW_READY_MAX_STALE_SECS=60
# Log filter (RUST_LOG syntax).
FW_RUST_LOG=forkwars_backend=info,tower_http=warn,axum::rejection=warn
# Optional: force coinbase-prevout resolution (requires txindex=1 on the nodes). Leave unset to let
# the backend decide by network. Uncomment only if you know you need it.
#FW_RESOLVE_PREVOUTS=0

# --- BIP-110 / RDTS milestones (all on 2016-block retarget boundaries) ---------------------------
# First epoch where bit-4 signaling is possible — the app's visible-history floor.
FW_FLOOR_HEIGHT=927360
# Countdown target: start of the MANDATORY SIGNALING window (blocks 961,632–963,647), the point at
# which the chain can actually split.
FW_FORK_AT_HEIGHT=961632
FW_FORK_LABEL="Mandatory signaling"
# Difficulty geometry — past the next retarget the ETA reverts to this protocol target.
FW_TARGET_SPACING_SECS=600
FW_RETARGET_INTERVAL=2016

# --- Node bootstrap (assumeutxo snapshot) --------------------------------------------------------
FW_LOAD_SNAPSHOT=/snapshots/utxo-840000.dat
FW_SNAPSHOT_HEIGHT=840000

# --- LAN exposure --------------------------------------------------------------------------------
# Host port for debugging the app directly (LAN users go through nginx on :80).
FW_APP_PORT=8081
# mDNS name advertised on the LAN.
FW_MDNS_NAME=forkwatch.local
